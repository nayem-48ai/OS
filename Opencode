#!/bin/bash

# --- Color Definitions ---
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
NC='\033[0m'

LOG_FILE="$HOME/.opencode_setup.log"

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    Opencode & Antigravity Auto-Setup         "
    echo "  ============================================="
    echo -e "${NC}\n"
}

# ক্লিন প্রোগ্রেস ইন্ডিকেটর (লগ ফাইল দেখাবে না)
show_status() {
    local task_name=$1
    local pids=$2
    local spin='|/-\'
    local i=0

    echo -ne "${BLUE}[*] ${task_name}...${NC}"
    
    while kill -0 $pids 2>/dev/null; do
        i=$(( (i+1) %4 ))
        printf "\r${BLUE}[*] ${task_name} ${YELLOW}[${spin:$i:1}]${NC}"
        sleep 0.2
    done
    printf "\r${GREEN}[✔] ${task_name} Completed!${NC}\n"
}

print_banner

# ১. সিস্টেম সেটআপ
(pkg update -y && pkg install proot-distro -y) >> "$LOG_FILE" 2>&1 &
show_status "Updating Termux" $!

if ! proot-distro list | grep -q "ubuntu.*installed"; then
    proot-distro install ubuntu >> "$LOG_FILE" 2>&1 &
    show_status "Installing Ubuntu" $!
fi

# ২. কনফিগারেশন
echo -e "${YELLOW}Phase: Configuring Environment...${NC}"
proot-distro login ubuntu -- bash -c "
  apt update -y && apt install curl -y
  curl -fsSL https://bun.sh/install | bash
  # লগ ফাইল এখানে আর ডাম্প করব না, সব সাইলেন্ট থাকবে
" >> "$LOG_FILE" 2>&1 &
show_status "Setting up Dependencies" $!

# ৪. ফাইনাল অথ
echo -e "\n${GREEN}➔ Launching Authentication... Please be patient, This may take a while...${NC}"
rm -f "$LOG_FILE"
proot-distro login ubuntu -- bash -c "opencode auth login"
