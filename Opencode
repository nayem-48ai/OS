#!/bin/bash

# --- Colors & UI ---
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; CYAN='\033[1;36m'; BOLD='\033[1m'; NC='\033[0m'
TICK="${GREEN}✔${NC}"

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    ____                                  __   "
    echo "   / __ \____  ___  ____  _________  ____/ /__ "
    echo "  / / / / __ \/ _ \/ __ \/ ___/ __ \/ __  / _ \\"
    echo " / /_/ / /_/ /  __/ / / / /__/ /_/ / /_/ /  __/"
    echo " \____/ .___/\___/_/ /_/\___/\____/\__,_/\___/ "
    echo "     /_/                                       "
    echo "        Opencode & Antigravity Auto-Setup      "
    echo "           Engineered by: Tnayem48             "
    echo "  ============================================="
    echo -e "${NC}\n"
}

# প্রতিটি কাজের জন্য ক্লিনার ফাংশন
step() {
    local task=$1
    echo -e "${BLUE}  ➔ ${NC}${task}..."
}

done_step() {
    # আগের লাইনটি মুছে দিয়ে টিক মার্ক বসানো
    printf "\033[1A\033[K"
    echo -e "  ${TICK} ${GREEN}Done:${NC} $1"
}

print_banner

echo -e "${YELLOW}Phase 1: Environment Preparation${NC}"
step "Updating System"
pkg update -y &> /dev/null && pkg upgrade -y &> /dev/null
done_step "Updating System"

step "Installing Dependencies"
pkg install proot-distro -y &> /dev/null
done_step "Installing Dependencies"

if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "  ${TICK} Ubuntu is already ready."
else
    step "Installing Ubuntu (This may take a moment)"
    proot-distro install ubuntu &> /dev/null
    done_step "Installing Ubuntu"
fi

echo -e "\n${YELLOW}Phase 2: Core System Configuration${NC}"
step "Preparing Internal RootFS"
ln -sf $PREFIX/var/lib/proot-distro/containers/ubuntu/rootfs ~/ubuntu-fs
done_step "Internal RootFS Linked"

step "Setting up Bun & Opencode (Please be patient)"
proot-distro login ubuntu -- bash -c "
  apt update -y &> /dev/null
  apt install curl bash -y &> /dev/null
  if [ ! -d \"\$HOME/.bun\" ]; then curl -fsSL https://bun.sh/install | bash &> /dev/null; fi
  curl -fsSL https://opencode.ai/install | bash &> /dev/null
" &> /dev/null
done_step "Bun & Opencode Configuration"

echo -e "\n${YELLOW}Phase 3: Finalization${NC}"
echo -e "${BLUE}[!] Please be patient. Finalizing authentication...${NC}"
proot-distro login ubuntu -- bash -c "opencode auth login"
