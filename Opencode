#!/bin/bash

# --- Colors ---
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; NC='\033[0m'

# --- Simple Spinner Function ---
spin() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while kill -0 "$pid" 2>/dev/null; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

print_header() {
    clear
    echo -e "${BLUE}=== Opencode Setup Assistant ===${NC}\n"
}

print_header

# ১. এনভায়রনমেন্ট সেটআপ
echo -n "[*] Updating system..."
(pkg update -y && pkg upgrade -y && pkg install proot-distro -y) > /dev/null 2>&1 &
spin $!
echo -e "${GREEN} Done!${NC}"

# উবুন্টু চেক
if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "${GREEN}✔ Ubuntu already installed.${NC}"
else
    echo -n "[*] Installing Ubuntu (This may take a moment)..."
    proot-distro install ubuntu > /dev/null 2>&1 &
    spin $!
    echo -e "${GREEN} Done!${NC}"
fi

# ২. কনফিগারেশন ও টুলস
echo -n "[*] Configuring Core Ecosystem..."
proot-distro login ubuntu -- bash -c "
  apt update > /dev/null 2>&1
  apt install curl bash -y > /dev/null 2>&1
  
  # Bun Setup
  if [ ! -d \"\$HOME/.bun\" ]; then
    curl -fsSL https://bun.sh/install | bash > /dev/null 2>&1
  fi
  
  # Opencode Setup
  curl -fsSL https://opencode.ai/install | bash > /dev/null 2>&1
  chmod +x ~/.opencode/bin/opencode
  cp ~/.opencode/bin/opencode /usr/bin/
" > /dev/null 2>&1 &
spin $!
echo -e "${GREEN} Done!${NC}"

# ৩. ফাইনাল হ্যান্ডশেক
echo -e "\n${YELLOW}➔ Launching Secure Authentication. Please be patient. This may take a while..${NC}"
sleep 1
proot-distro login ubuntu -- bash -c "opencode auth login"
