#!/bin/bash

# --- Colors & UI ---
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; CYAN='\033[1;36m'; BOLD='\033[1m'; NC='\033[0m'
TICK="${GREEN}✔${NC}"
PROC="${BLUE}➜${NC}" # [*]-এর বদলে আধুনিক অ্যারো আইকন

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    ____                                  __   "
    echo "   / __ \____  ___  ____  _________  ____/ /__ "
    echo "  / / / / __ \/ _ \/ __ \/ ___/ __ \/ __  / _ \\"
    echo " / /_/ / /_/ /  __/ / / / /__/ /_/ / /_/ /  __/"
    echo " \____/ .___/\___/_/ /_/\___/\____/\__,_/\___/ "
    echo "     /_/                                       "
    echo "        Opencode & Antigravity Auto-Setup      "
    echo "           Engineered by: Tnayem48             "
    echo "  ============================================="
    echo -e "${NC}\n"
}

run_animated_task() {
    local task_name=$1
    local command=$2
    local spinner=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    
    eval "$command" &> /dev/null &
    local pid=$!
    local i=0
    
    printf "  ${PROC} ${task_name}..."
    while kill -0 $pid 2>/dev/null; do
        printf "\b${spinner[$i]}"
        i=$(( (i+1) % 10 ))
        sleep 0.1
    done
    printf "\b${TICK}\n"
}

print_banner

# ১. এনভায়রনমেন্ট
echo -e "${YELLOW}Phase 1: Environment Setup${NC}"
run_animated_task "Updating system" "pkg update -y && pkg upgrade -y"
run_animated_task "Installing dependencies" "pkg install proot-distro -y"

if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "  ${TICK} ${GREEN}Ubuntu container is ready${NC}\n"
else
    echo -e "  ${PROC} ${BLUE}Installing Ubuntu (This may take a moment)...${NC}"
    proot-distro install ubuntu &> /dev/null
    echo -e "  ${TICK} ${GREEN}Ubuntu installation completed!${NC}\n"
fi

# ২. কনফিগারেশন ও বাইনারি লিংক
echo -e "${YELLOW}Phase 2: Core System Configuration${NC}"
run_animated_task "Initializing environment" "proot-distro login ubuntu -- bash -c 'apt update -y && apt install curl bash -y' &> /dev/null"
run_animated_task "Setting up Bun" "proot-distro login ubuntu -- bash -c 'if [ ! -d \"\$HOME/.bun\" ]; then curl -fsSL https://bun.sh/install | bash; fi' &> /dev/null"
run_animated_task "Deploying Opencode CLI" "proot-distro login ubuntu -- bash -c 'curl -fsSL https://opencode.ai/install | bash && cp ~/.opencode/bin/opencode /usr/local/bin/' &> /dev/null"

# ৩. ফাইনাল হ্যান্ডশেক
echo -e "${YELLOW}Phase 3: Finalization${NC}"
echo -e "${BLUE}  [!] Please be patient. This may take a while as we finalize authentication...${NC}\n"

# সরাসরি উবুন্টু এনভায়রনমেন্টে লগইন করে কমান্ড রান
proot-distro login ubuntu -- opencode auth login
