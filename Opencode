# ৩. উবুন্টুর ভেতরে সেটআপ
proot-distro login ubuntu -- bash -c "
  apt update && apt install curl bash -y > /dev/null 2>&1
  
  if [ ! -d \"\$HOME/.bun\" ]; then
    curl -fsSL https://bun.sh/install | bash > /dev/null 2>&1
  fi
  
  grep -q 'BUN_INSTALL' ~/.bashrc || echo 'export BUN_INSTALL=\"\$HOME/.bun\"' >> ~/.bashrc
  grep -q 'PATH.*\.bun' ~/.bashrc || echo 'export PATH=\"\$BUN_INSTALL/bin:\$PATH\"' >> ~/.bashrc
  
  export BUN_INSTALL=\"\$HOME/.bun\"
  export PATH=\"\$BUN_INSTALL/bin:\$PATH\"
  
  curl -fsSL https://opencode.ai/install | bash > /dev/null 2>&1
  chmod +x ~/.opencode/bin/opencode
  ln -sf ~/.opencode/bin/opencode /usr/bin/opencode
  
  mkdir -p ~/.config/opencode/
  echo '$JSON_DATA' > ~/.config/opencode/opencode.json
" &
show_progress 45 "Configuring Ubuntu Ecosystem (Bun, Engines, Configs)" $!

# ৪. হ্যান্ডশেক
echo -e "${YELLOW}${BOLD}➔ Launching Secure Authentication Handshake...${NC}"
echo -e "${BLUE}[!] Please be patient. This may take a while as we finalize authentication...${NC}\n"
sleep 1.5

proot-distro login ubuntu -- opencode auth login
