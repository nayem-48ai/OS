#!/bin/bash

# --- Colors & UI ---
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; CYAN='\033[1;36m'; BOLD='\033[1m'; NC='\033[0m'
TICK="${GREEN}✔${NC}"

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    ____                                  __   "
    echo "   / __ \____  ___  ____  _________  ____/ /__ "
    echo "  / / / / __ \/ _ \/ __ \/ ___/ __ \/ __  / _ \\"
    echo " / /_/ / /_/ /  __/ / / / /__/ /_/ / /_/ /  __/"
    echo " \____/ .___/\___/_/ /_/\___/\____/\__,_/\___/ "
    echo "     /_/                                       "
    echo "        Opencode & Antigravity Auto-Setup      "
    echo "           Engineered by: Tnayem48             "
    echo "  ============================================="
    echo -e "${NC}\n"
}

# ক্লিন স্পিনার ফাংশন
run_task() {
    local msg=$1
    local cmd=$2
    printf "  ${BLUE}[*] ${msg}..."
    eval "$cmd" &> /dev/null
    printf "\r  ${TICK} ${GREEN}${msg} Done!${NC}\n"
}

print_banner

# ১. এনভায়রনমেন্ট
echo -e "${YELLOW}Phase 1: Environment Preparation${NC}"
run_task "Updating System" "pkg update -y && pkg upgrade -y"
run_task "Installing Proot-Distro" "pkg install proot-distro -y"

if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "  ${TICK} ${GREEN}Ubuntu already configured.${NC}\n"
else
    printf "  ${BLUE}[*] Installing Ubuntu (This takes time)...${NC}"
    proot-distro install ubuntu &> /dev/null
    printf "\r  ${TICK} ${GREEN}Ubuntu Installation Done!${NC}\n\n"
fi

ln -sf $PREFIX/var/lib/proot-distro/containers/ubuntu/rootfs ~/ubuntu-fs

# ২. কনফিগারেশন
echo -e "${YELLOW}Phase 2: Core System Configuration${NC}"
printf "  ${BLUE}[*] Setting up dependencies (Please be patient)...${NC}"

proot-distro login ubuntu -- bash -c "
  apt update -y &> /dev/null
  apt install curl bash -y &> /dev/null
  if [ ! -d \"\$HOME/.bun\" ]; then curl -fsSL https://bun.sh/install | bash &> /dev/null; fi
  curl -fsSL https://opencode.ai/install | bash &> /dev/null
  mkdir -p ~/.config/opencode/
" &> /dev/null
printf "\r  ${TICK} ${GREEN}Core Configuration Done!${NC}\n\n"

# ৩. হ্যান্ডশেক
echo -e "${YELLOW}Phase 3: Finalization${NC}"
echo -e "${BLUE}[!] Please be patient. This may take a while as we finalize authentication...${NC}\n"

proot-distro login ubuntu -- bash -c "opencode auth login"
