#!/bin/bash

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}--- Opencode & Antigravity Auto Setup by Tnayem48 is Started ---${NC}"

# ১. প্রুট ও আর্চলাইন্যাক্স সেটআপ
echo -e "${GREEN}[1/4] Installing Proot-Distro and ArchLinux...${NC}"
pkg update && pkg upgrade -y
pkg install proot-distro -y
proot-distro install archlinux || echo "ArchLinux already exists, skipping install..."

# ২. আর্চলাইন্যাক্স কনফিগারেশন
echo -e "${GREEN}[2/4] Configuring ArchLinux Environment...${NC}"
proot-distro login archlinux -- bash -c "
  pacman -Syu --noconfirm
  pacman -S curl bash --noconfirm

  # Bun ইনস্টল
  curl -fsSL https://bun.sh/install | bash
  export BUN_INSTALL=\"\$HOME/.bun\"
  export PATH=\"\$BUN_INSTALL/bin:\$PATH\"
  
  # Opencode ইনস্টল
  curl -fsSL https://opencode.ai/install | bash
  chmod +x ~/.opencode/bin/opencode
  cp ~/.opencode/bin/opencode /usr/bin/

  # কনফিগারেশন ও JSON তৈরি
  mkdir -p ~/.config/opencode/
  cat << 'JSON' > ~/.config/opencode/opencode.json
{
  \"\$schema\": \"https://opencode.ai/config.json\",
  \"plugin\": [\"opencode-antigravity-auth\"],
  \"provider\": {
    \"google\": {
      \"models\": {
        \"antigravity-gemini-3-pro\": { \"name\": \"Gemini 3 Pro (Antigravity)\", \"limit\": { \"context\": 1048576, \"output\": 65535 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] }, \"variants\": { \"low\": { \"thinkingLevel\": \"low\" }, \"high\": { \"thinkingLevel\": \"high\" } } },
        \"antigravity-gemini-3.1-pro\": { \"name\": \"Gemini 3.1 Pro (Antigravity)\", \"limit\": { \"context\": 1048576, \"output\": 65535 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] }, \"variants\": { \"low\": { \"thinkingLevel\": \"low\" }, \"high\": { \"thinkingLevel\": \"high\" } } },
        \"antigravity-gemini-3-flash\": { \"name\": \"Gemini 3 Flash (Antigravity)\", \"limit\": { \"context\": 1048576, \"output\": 65536 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] }, \"variants\": { \"minimal\": { \"thinkingLevel\": \"minimal\" }, \"low\": { \"thinkingLevel\": \"low\" }, \"medium\": { \"thinkingLevel\": \"medium\" }, \"high\": { \"thinkingLevel\": \"high\" } } },
        \"antigravity-claude-sonnet-4-6\": { \"name\": \"Claude Sonnet 4.6 (Antigravity)\", \"limit\": { \"context\": 200000, \"output\": 64000 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"antigravity-claude-opus-4-6-thinking\": { \"name\": \"Claude Opus 4.6 Thinking (Antigravity)\", \"limit\": { \"context\": 200000, \"output\": 64000 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] }, \"variants\": { \"low\": { \"thinkingConfig\": { \"thinkingBudget\": 8192 } }, \"max\": { \"thinkingConfig\": { \"thinkingBudget\": 32768 } } } },
        \"gemini-2.5-flash\": { \"name\": \"Gemini 2.5 Flash (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65536 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"gemini-2.5-pro\": { \"name\": \"Gemini 2.5 Pro (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65536 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"gemini-3-flash-preview\": { \"name\": \"Gemini 3 Flash Preview (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65536 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"gemini-3-pro-preview\": { \"name\": \"Gemini 3 Pro Preview (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65535 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"gemini-3.1-pro-preview\": { \"name\": \"Gemini 3.1 Pro Preview (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65535 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } },
        \"gemini-3.1-pro-preview-customtools\": { \"name\": \"Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)\", \"limit\": { \"context\": 1048576, \"output\": 65535 }, \"modalities\": { \"input\": [\"text\", \"image\", \"pdf\"], \"output\": [\"text\"] } }
      }
    }
  }
}
JSON

  echo -e '${GREEN}[3/4] Setup Complete!${NC}'
  echo -e '${YELLOW}[4/4] Starting Authentication...${NC}'
  opencode auth login
"
