#!/bin/bash

# --- Color Definitions & UI Elements ---
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
BOLD='\033[1m'
NC='\033[0m'

TICK="${GREEN}✔${NC}"
CROSS="${RED}✘${NC}"

# --- Slim Banner for All Screen Sizes ---
print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    ____                                  __   "
    echo "   / __ \____  ___  ____  _________  ____/ /__ "
    echo "  / / / / __ \/ _ \/ __ \/ ___/ __ \/ __  / _ \\"
    echo " / /_/ / /_/ /  __/ / / / /__/ /_/ / /_/ /  __/"
    echo " \____/ .___/\___/_/ /_/\___/\____/\__,_/\___/ "
    echo "     /_/                                       "
    echo "        Opencode & Antigravity Auto-Setup      "
    echo "           Engineered by: Tnayem48             "
    echo "  ============================================="
    echo -e "${NC}\n"
}

# --- Hybrid Spinner + 0-100% Progress Bar ---
show_progress() {
    local duration=$1
    local task_name=$2
    local pids=$3
    local elapsed=0
    local fill_char="█"
    local empty_char="░"
    local total_blocks=20
    local spinstr='|/-\'

    echo -e "${BLUE}[*] ${task_name}...${NC}"

    # ব্যাকগ্রাউন্ড প্রসেস চলাকালীন লুপ চলবে
    while kill -0 $pids 2>/dev/null; do
        # স্পিনার লজিক
        local temp=${spinstr#?}
        local current_spin=$spinstr
        spinstr=$temp${spinstr%"$temp"}

        # প্রোগ্রেস বার ও পার্সেন্টেজ লজিক (ভার্চুয়াল টাইমিং বেসড সেফগার্ড)
        let elapsed++
        local percent=$(( (elapsed * 100) / duration ))
        if [ $percent -gt 98 ]; then percent=98; fi # প্রসেস শেষ না হওয়া পর্যন্ত ৯৮% এ হোল্ড করবে

        local filled_blocks=$(( (percent * total_blocks) / 100 ))
        local empty_blocks=$(( total_blocks - filled_blocks ))

        local bar=""
        for ((i=0; i<filled_blocks; i++)); do bar+="$fill_char"; done
        for ((i=0; i<empty_blocks; i++)); do bar+="$empty_char"; done

        # ক্যারেজ রিটার্ন (\r) দিয়ে একই লাইনে স্পিনার ও বার প্রিন্ট করা
        printf "\r  ${YELLOW}[%c]${NC} ${CYAN}[%-20s]${NC} %d%%" "${current_spin:0:1}" "$bar" "$percent"
        
        sleep 0.15
    done
    
    # প্রসেস সাকসেসফুলি শেষ হলে ফোর্সড ১০০% শো করা
    local full_bar=""
    for ((i=0; i<total_blocks; i++)); do full_bar+="$fill_char"; done
    printf "\r  ${TICK} ${CYAN}[%-20s]${NC} 100%%\n" "$full_bar"
    echo -e "  ${GREEN}➔ ${task_name} Completed!${NC}\n"
}

# --- Main Script Execution ---
print_banner

# ১. প্রুট ও উবুন্টু সেটআপ
# এখানে আমরা টার্মিনক্সের প্যাকেজ ম্যানেজার আপডেট স্ক্রিনে দেখাবো না, তবে প্রুট ডিস্ট্রোর ইনফো ইউজার দেখতে পাবে
(pkg update && pkg upgrade -y && pkg install proot-distro -y) > /dev/null 2>&1 &
show_progress 30 "Updating Termux & System Core" $!

if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "  ${GREEN}✔ Ubuntu environment already exists. Ready to inject.${NC}\n"
else
    # প্রুট ডিস্ট্রো ইনস্টলেশনের মূল আউটপুটটি স্ক্রিনে আসতে দেওয়া হলো যাতে ইউজার দেখতে পায় উবুন্টু রেডি হচ্ছে
    proot-distro install ubuntu &
    show_progress 60 "Downloading & Deploying Ubuntu Core" $!
fi

# ২. এনভায়রনমেন্ট ও কনফিগারেশন ডাটা
