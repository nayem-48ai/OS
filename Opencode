#!/bin/bash

# --- Colors & UI ---
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; CYAN='\033[1;36m'; BOLD='\033[1m'; NC='\033[0m'
TICK="${GREEN}✔${NC}"

print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ============================================="
    echo "    ____                                  __   "
    echo "   / __ \____  ___  ____  _________  ____/ /__ "
    echo "  / / / / __ \/ _ \/ __ \/ ___/ __ \/ __  / _ \\"
    echo " / /_/ / /_/ /  __/ / / / /__/ /_/ / /_/ /  __/"
    echo " \____/ .___/\___/_/ /_/\___/\____/\__,_/\___/ "
    echo "     /_/                                       "
    echo "        Opencode & Antigravity Auto-Setup      "
    echo "           Engineered by: Tnayem48             "
    echo "  ============================================="
    echo -e "${NC}\n"
}

# অ্যানিমেটেড লোডার ফাংশন
run_animated_task() {
    local task_name=$1
    local command=$2
    local spinner=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    
    # ব্যাকগ্রাউন্ডে কমান্ড রান করা
    eval "$command" &> /dev/null &
    local pid=$!
    
    local i=0
    printf "  ${BLUE}[*] ${task_name}... "
    
    # যতক্ষণ কমান্ড চলছে, স্পিনার ঘোরানো
    while kill -0 $pid 2>/dev/null; do
        printf "\b${spinner[$i]}"
        i=$(( (i+1) % 10 ))
        sleep 0.1
    done
    
    printf "\b${TICK}\n"
}

print_banner

# ১. এনভায়রনমেন্ট সেটআপ
echo -e "${YELLOW}Phase 1: Environment Setup${NC}"
run_animated_task "Updating system packages" "pkg update -y && pkg upgrade -y"
run_animated_task "Preparing core dependencies" "pkg install proot-distro -y"

if proot-distro list | grep -q "ubuntu.*installed"; then
    echo -e "  ${TICK} ${GREEN}Ubuntu container is ready${NC}\n"
else
    # বড় কাজের জন্য আলাদা স্টাইল
    echo -e "  ${BLUE}[!]${NC} Downloading Ubuntu (This may take a moment)..."
    proot-distro install ubuntu &> /dev/null
    echo -e "  ${TICK} ${GREEN}Ubuntu installation completed!${NC}\n"
fi

# ২. কনফিগারেশন
echo -e "${YELLOW}Phase 2: Core System Configuration${NC}"
run_animated_task "Initializing Ubuntu environment" "proot-distro login ubuntu -- bash -c 'apt update -y &> /dev/null'"
run_animated_task "Installing necessary runtimes" "proot-distro login ubuntu -- bash -c 'apt install curl bash -y &> /dev/null'"
run_animated_task "Configuring Bun engine" "proot-distro login ubuntu -- bash -c 'if [ ! -d \"\$HOME/.bun\" ]; then curl -fsSL https://bun.sh/install | bash &> /dev/null; fi'"
run_animated_task "Deploying Opencode CLI" "proot-distro login ubuntu -- bash -c 'curl -fsSL https://opencode.ai/install | bash &> /dev/null && mkdir -p ~/.config/opencode/'"

# ৩. ফাইনাল হ্যান্ডশেক
echo -e "${YELLOW}Phase 3: Finalization${NC}"
echo -e "${BLUE}[!] Please be patient. This may take a while as we finalize authentication...${NC}\n"

# হ্যান্ডশেকের সময় বাফার ক্লিয়ার করে সিকিউর লগইন
proot-distro login ubuntu -- bash -c "opencode auth login"
