# ৩. উবুন্টুর ভেতরে ইন্টারনাল সেটআপ রান করা
# এখানে apt update এর গুরুত্বপূর্ণ ট্রাফিক হিটগুলো স্ক্রিনে প্রিন্ট হবে, কিন্তু বাকি ইনস্টলেশন ব্যাকগ্রাউন্ডে প্রোগ্রেস বারে চলবে।
proot-distro login ubuntu -- bash -c "
  apt update
  apt upgrade -y > /dev/null 2>&1
  apt install curl bash -y > /dev/null 2>&1

  # Bun Environment Setup
  if [ ! -d \"\$HOME/.bun\" ]; then
    curl -fsSL https://bun.sh/install | bash > /dev/null 2>&1
  fi
  
  grep -q 'BUN_INSTALL' ~/.bashrc || echo 'export BUN_INSTALL=\"\$HOME/.bun\"' >> ~/.bashrc
  grep -q 'PATH.*\.bun' ~/.bashrc || echo 'export PATH=\"\$BUN_INSTALL/bin:\$PATH\"' >> ~/.bashrc
  
  export BUN_INSTALL=\"\$HOME/.bun\"
  export PATH=\"\$BUN_INSTALL/bin:\$PATH\"
  
  # Opencode Installation
  curl -fsSL https://opencode.ai/install | bash > /dev/null 2>&1
  chmod +x ~/.opencode/bin/opencode
  cp ~/.opencode/bin/opencode /usr/bin/

  # Injecting Config
  mkdir -p ~/.config/opencode/
  cat << 'EOF' > ~/.config/opencode/opencode.json
$JSON_DATA
EOF
" &
show_progress 45 "Configuring Ubuntu Ecosystem (Bun, Engines, Configs)" $!

# ৪. ফাইনাল হ্যান্ডশেক এবং অথেন্টিকেশন
echo -e "${YELLOW}${BOLD}➔ Launching Secure Authentication Handshake...${NC}"
echo -e "${BLUE}[!] System is switching control to Opencode CLI.${NC}\n"
sleep 1.5

proot-distro login ubuntu -- bash -c "opencode auth login"
